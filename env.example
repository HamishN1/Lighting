# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# -----------------------------------------------------------
# Anthropic API Key (required)
# Get yours at: https://console.anthropic.com
# This key is only used server-side (in /api routes) — never exposed to the browser.
# -----------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -----------------------------------------------------------
# App URL (used for absolute URLs in emails etc.)
# -----------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------
# Optional: Supabase (for real auth + database)
# If not set, the app uses localStorage for demo purposes.
# Get yours at: https://supabase.com
# -----------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
